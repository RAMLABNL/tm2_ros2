<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tm14sx">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import tm14sx urdf file -->
    <xacro:include filename="$(find tm_description)/xacro/tm14sx.urdf.xacro" />

    <!-- Import control_xacro -->
    <xacro:include filename="tm14sx.ros2_control.xacro" />


    <xacro:tm14sx_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
