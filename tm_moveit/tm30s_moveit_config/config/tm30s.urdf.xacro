<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tm30s">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import tm30s urdf file -->
    <xacro:include filename="$(find tm_description)/xacro/tm30s.urdf.xacro" />

    <!-- Import control_xacro -->
    <xacro:include filename="tm30s.ros2_control.xacro" />


    <xacro:tm30s_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
