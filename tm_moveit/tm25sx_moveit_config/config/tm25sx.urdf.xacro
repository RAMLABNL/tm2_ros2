<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tm25sx">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import tm25sx urdf file -->
    <xacro:include filename="$(find tm_description)/xacro/tm25sx.urdf.xacro" />

    <!-- Import control_xacro -->
    <xacro:include filename="tm25sx.ros2_control.xacro" />


    <xacro:tm25sx_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
