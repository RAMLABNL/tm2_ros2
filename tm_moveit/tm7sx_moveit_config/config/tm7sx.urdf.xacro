<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tm7sx">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import tm7sx urdf file -->
    <xacro:include filename="$(find tm_description)/xacro/tm7sx.urdf.xacro" />

    <!-- Import control_xacro -->
    <xacro:include filename="tm7sx.ros2_control.xacro" />


    <xacro:tm7sx_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
